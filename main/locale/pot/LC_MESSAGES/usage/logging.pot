#: ../../../usage/logging.rst:4
msgid "Request logging"
msgstr ""

#: ../../../usage/logging.rst:6
msgid ""
"Litestar can be configured to log information about requests / responses, "
"via :class:`~litestar.middleware.logging.LoggingMiddleware`. In that, it is "
"agnostic about the logging set up, or which logging library is used. You can "
"pass in any object that conforms to the :class:`logging.Logger` interface, "
"or a callable that returns such a logger."
msgstr ""

#: ../../../usage/logging.rst:13
msgid ""
"import logging\n"
"\n"
"from litestar import Litestar, get\n"
"from litestar.middleware.logging import LoggingMiddleware\n"
"\n"
"\n"
"@get(\"/\")\n"
"async def my_handler() -> dict[str, str]:\n"
"    return {\"hello\": \"world\"}\n"
"\n"
"\n"
"app = Litestar(\n"
"    route_handlers=[my_handler],\n"
"    middleware=[\n"
"        LoggingMiddleware(\n"
"            logging.getLogger(\"my.app\"),\n"
"            request_log_fields=(\"query\", \"body\"),  # only log query and "
"body fields\n"
"        )\n"
"    ],\n"
")"
msgstr ""

