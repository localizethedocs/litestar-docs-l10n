#: ../../../release-notes/changelog.rst:4
msgid "3.x Changelog"
msgstr ""

#: ../../../release-notes/changelog.rst:13
msgid "Drop support for Pydantic 1."
msgstr ""

#: ../../../release-notes/changelog.rst:15
msgid ""
"Pydantic 1 is no longer supported or tested against. No changes required for "
"applications already using Pydantic 2. Applications using Pydantic 1 or a "
"mix between 1 and 2 should upgrade to Pydantic 2."
msgstr ""

#: ../../../release-notes/changelog.rst:24
msgid ""
"Added optional ``ping_interval`` parameter to :class:`ServerSentEvent "
"<litestar.response.ServerSentEvent>` that sends SSE comment keepalive pings "
"at the specified interval to prevent connection timeouts from reverse "
"proxies or clients."
msgstr ""

